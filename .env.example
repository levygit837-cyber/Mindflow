# OmniMind v1 (Python backend + PySide6 desktop)

# ============================================================
# App Runtime
# ============================================================
APP_NAME=OmniMind
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================
# Data + Queue
# ============================================================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/omnimind
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Default LLM Provider & Model
# ============================================================
# Provider options: anthropic | openai | ollama | google | vertexai
DEFAULT_PROVIDER=vertexai
DEFAULT_MODEL=gemini-3-flash-preview

# ============================================================
# LLM API Keys / Endpoints
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Vertex AI optional credentials
VERTEXAI_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# ============================================================
# Tooling / Search
# ============================================================
SEARXNG_URL=http://localhost:8080

# ============================================================
# Allowed project roots (comma-separated absolute paths)
# Bootstrapped into DB table allowed_paths at startup.
# ============================================================
OMNIMIND_ALLOWED_PATHS=/home/levybonito/Projetos

# ============================================================
# Desktop defaults
# ============================================================
OMNIMIND_API_URL=http://127.0.0.1:8000
CODEX_HOME=/home/levybonito/.codex
