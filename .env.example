# Environment Variables for MindFlow

# ============================================================================
# Security Configuration (Phase 0)
# ============================================================================

# JWT Secret Key (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=<generate_secure_random_key>

# ============================================================================
# Database Configuration
# ============================================================================

DATABASE_URL=postgresql://mindflow_app:mindflow_dev_local_2026@localhost:5433/mindflow_v1

# ============================================================================
# RabbitMQ Configuration
# ============================================================================

RABBITMQ_URL=amqp://guest:guest@localhost:5673/
ENABLE_RABBITMQ=false

# ============================================================================
# gRPC Configuration
# ============================================================================

GRPC_ENABLED=false

# ============================================================================
# Google Cloud / Vertex AI
# ============================================================================

GOOGLE_API_KEY=<your_google_api_key>
# OR
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ============================================================================
# Agent Configuration
# ============================================================================

MINDFLOW_ALLOWED_PATHS=/home/user/workspace,/tmp/mindflow

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_LLM_PLANNING_TRIGGER=false

# ============================================================================
# LightPanda Browser Service Configuration
# ============================================================================

# LightPanda Browser Management Configuration
LIGHTPANDA_USE_REAL_DOCKER=true
LIGHTPANDA_RATE_LIMIT_PER_MINUTE=10
LIGHTPANDA_HEALTH_CHECK_INTERVAL=30
LIGHTPANDA_MAX_METRICS_PER_INSTANCE=1000
LIGHTPANDA_METRICS_RETENTION_SECONDS=3600
LIGHTPANDA_INSTANCE_DATA_RETENTION_SECONDS=7200

# LightPanda Snapshot Persistence
SNAPSHOT_FALLBACK_DIR=/var/lib/mindflow/snapshots
SNAPSHOT_RETENTION_SECONDS=3600


# LightPanda Container Configuration
LIGHTPANDA_CONTAINER_NAME=mindflow-lightpanda-v1
LIGHTPANDA_PORT=9222
LIGHTPANDA_HOST=127.0.0.1

# LightPanda Browser Management
LIGHTPANDA_MAX_INSTANCES=5
LIGHTPANDA_SNAPSHOT_INTERVAL=300
LIGHTPANDA_SNAPSHOT_RETENTION=3600
LIGHTPANDA_BROWSER_IDLE_TIMEOUT=600
LIGHTPANDA_BROWSER_MAX_LIFETIME=3600

# LightPanda Performance Configuration
LIGHTPANDA_REQUEST_TIMEOUT=30
LIGHTPANDA_NAVIGATION_TIMEOUT=15
LIGHTPANDA_PAGE_LOAD_TIMEOUT=10

# ============================================================================
# LightPanda Advanced Features (Phase 1 Implementation)
# ============================================================================

# Browser Pool Configuration
BROWSER_POOL_MIN=2
BROWSER_POOL_MAX=20
BROWSER_POOL_WARM=3
BROWSER_POOL_SCALE_UP_THRESHOLD=0.7
BROWSER_POOL_SCALE_DOWN_THRESHOLD=0.3

# Session Persistence
BROWSER_SESSION_TTL_HOURS=24

# Performance Optimization
BROWSER_CACHE_ENABLED=true
BROWSER_CACHE_TTL_SECONDS=3600
BROWSER_CACHE_MAX_SIZE=1000
BROWSER_PARALLEL_MAX_CONCURRENCY=5

# Network Interception
BROWSER_BLOCK_IMAGES=false
BROWSER_BLOCK_FONTS=false
BROWSER_BLOCK_TRACKERS=true

# Security & Isolation
BROWSER_USER_AGENT_ROTATION=true
BROWSER_PROXY_ROTATION=false

