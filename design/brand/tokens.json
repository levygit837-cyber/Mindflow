{
  "brand": "OmniMind",
  "theme": "Neural Dark",
  "version": "1.0.0",
  "colors": {
    "background": "#0A0A0B",
    "surface": "#121214",
    "surface_elevated": "#1A1A1E",
    "primary": "#5D3FD3",
    "secondary": "#2E2E32",
    "text": {
      "primary": "#E1E1E6",
      "secondary": "#A8A8B3",
      "disabled": "#737380",
      "inverse": "#0A0A0B"
    },
    "states": {
      "thinking": "#5D3FD3",
      "action": "#FFBF00",
      "success": "#04D361",
      "error": "#E83F5B",
      "warning": "#FFCD33",
      "info": "#2196F3"
    },
    "agents": {
      "coder": "#00FF41",
      "analyst": "#00E5FF",
      "researcher": "#7C4DFF",
      "arch_tech": "#B0BEC5",
      "critic": "#FF7043"
    }
  },
  "typography": {
    "font_family_mono": "'JetBrains Mono', 'Fira Code', monospace",
    "font_family_sans": "'Inter', 'Segoe UI', sans-serif",
    "base_font_size": "16px",
    "line_height_base": "1.5"
  },
  "spacing": {
    "base": "8px",
    "scale": [0, 4, 8, 16, 24, 32, 48, 64]
  },
  "effects": {
    "glass": {
      "blur": "12px",
      "opacity": "0.72",
      "border": "1px solid rgba(255, 255, 255, 0.1)"
    }
  }
}
