{
  "mcpServers": {
    "contextplus": {
      "command": "npx",
      "args": [
        "-y",
        "contextplus"
      ],
      "cwd": "/home/levybonito/Mindflow",
      "env": {
        "OLLAMA_EMBED_MODEL": "qwen3-embedding:0.6b",
