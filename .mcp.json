{
  "mcpServers": {
    "contextplus": {
      "command": "npx",
      "args": [
        "-y",
        "contextplus"
      ],
      "env": {
        "OLLAMA_EMBED_MODEL": "${OLLAMA_EMBED_MODEL:-qwen3-embedding:0.6b}",
        "OLLAMA_CHAT_MODEL": "${OLLAMA_CHAT_MODEL:-qwen3:8b}",
        "OLLAMA_API_KEY": "${OLLAMA_API_KEY}",
        "CONTEXTPLUS_EMBED_BATCH_SIZE": "8",
        "CONTEXTPLUS_EMBED_TRACKER": "lazy"
      }
    }
  }
}
