import React, { useMemo, useState } from 'react';
import { motion } from 'framer-motion';
import {
  AlertCircle,
  ArrowRight,
  CheckCircle2,
  ChevronDown,
  ChevronUp,
  Database,
  Loader2,
  Route,
  Search,
  TerminalSquare,
  Workflow,
} from 'lucide-react';
import { RichText } from '../common/RichText';
import {
  getMindflowV2AgentTheme,
  summarizeMindflowV2Value,
  type MindflowV2AgentType,
  type MindflowV2Tone,
} from './mindflowV2';

interface ThinkingNotifierProps {
  agentType: MindflowV2AgentType;
  active?: boolean;
  status?: string;
  className?: string;
}

interface ThinkingNotifierRowProps {
  activeAgents: MindflowV2AgentType[];
  statuses?: Partial<Record<MindflowV2AgentType, string>>;
  className?: string;
}

interface ThoughtBlockProps {
  agentType: MindflowV2AgentType;
  title?: string;
  status?: string;
  content: string;
  summary?: string;
  defaultExpanded?: boolean;
  className?: string;
}

interface DelegationAgentRow {
  name: string;
  role: string;
  status: string;
  accent?: string;
  agentType?: MindflowV2AgentType;
}

interface DelegationCardProps {
  title?: string;
  subtitle?: string;
  status?: string;
  pipeline?: string;
  summary?: string;
  agents: DelegationAgentRow[];
  variant?: 'simple' | 'rich';
  accent?: string;
  onOpenJourney?: () => void;
  className?: string;
}

interface ToolEventCardProps {
  toolName: string;
  status: 'running' | 'completed' | 'error' | 'collapsed';
  args?: unknown;
  result?: unknown;
  error?: string;
  elapsed?: string;
  agentName?: string;
  className?: string;
}

interface StreamNotifierProps {
  title: string;
  status: string;
  message?: string;
  detail?: string;
  tone?: MindflowV2Tone;
  className?: string;
}

interface MemoryRecallCardProps {
  source: 'vector' | 'database';
  status: string;
  label?: string;
  count?: number;
  detail?: string;
  agentName?: string;
  done?: boolean;
  className?: string;
}

export interface JourneyStep {
  id: string;
  title: string;
  detail: string;
  status: 'live' | 'done' | 'queued' | 'waiting' | 'error';
  agentType?: MindflowV2AgentType;
  meta?: string;
}

interface JourneyTimelineProps {
  title?: string;
  subtitle?: string;
  steps: JourneyStep[];
  summary?: string;
  durationLabel?: string;
  liveLabel?: string;
  activeStepId?: string;
  className?: string;
}

function cn(...parts: Array<string | false | null | undefined>) {
  return parts.filter(Boolean).join(' ');
}

function normalizeText(value: unknown): string {
  if (value === null || value === undefined) {
    return '';
  }

  return String(value).trim();
}

function statusToneClass(tone: MindflowV2Tone) {
  switch (tone) {
    case 'accent':
      return 'stream-notifier--accent';
    case 'info':
      return 'stream-notifier--info';
    case 'success':
      return 'stream-notifier--success';
    case 'warning':
      return 'stream-notifier--warning';
    case 'error':
      return 'stream-notifier--error';
    case 'neutral':
    default:
      return 'stream-notifier--neutral';
  }
}

function toolToneClass(status: ToolEventCardProps['status']) {
  switch (status) {
    case 'completed':
      return 'tool-event-card--success';
    case 'error':
      return 'tool-event-card--error';
    case 'collapsed':
    case 'running':
    default:
      return 'tool-event-card--warning';
  }
}

function memoryToneClass(source: 'vector' | 'database') {
  return source === 'database' ? 'memory-event--info' : 'memory-event--accent';
}

function statusLabel(status: JourneyStep['status']) {
  switch (status) {
    case 'live':
      return 'ao vivo';
    case 'done':
      return 'concluído';
    case 'queued':
      return 'na fila';
    case 'waiting':
      return 'aguardando';
    case 'error':
      return 'erro';
    default:
      return status;
  }
}

function formatThinkingStatus(status?: string) {
  const normalized = String(status ?? '').trim().toLowerCase();

  if (normalized.includes('think')) return 'pensando';
  if (normalized.includes('wait')) return 'aguardando';
  if (normalized.includes('active')) return 'ativo';
  if (normalized.includes('idle')) return 'ocioso';
  if (normalized.includes('expand')) return 'expandido';
  if (normalized.includes('collap')) return 'recolhido';
  if (normalized.includes('decision')) return 'decisão';
  if (normalized.includes('thought')) return 'pensamento';

  return status ?? '';
}

function formatSourceLabel(source: 'vector' | 'database') {
  return source === 'vector' ? 'Vector Memory Recall' : 'Database Memory Recall';
}

// Reasoning Depth Indicator — 3 segments, agent accent color (design: JI17t/1prPK)
function ReasoningDepthBar({ content, accent }: { content: string; accent: string }) {
  const depth = content.length < 300 ? 1 : content.length < 800 ? 2 : 3;
  return (
    <div style={{ display: 'flex', gap: 3, marginBottom: 4 }}>
      {[1, 2, 3].map((seg) => (
        <span
          key={seg}
          style={{
            height: 3,
            width: 20,
            borderRadius: 2,
            background: seg <= depth ? accent : 'var(--line-primary, #E5E5E5)',
            transition: 'background 0.2s',
          }}
        />
      ))}
    </div>
  );
}

export const ThinkingNotifier: React.FC<ThinkingNotifierProps> = ({
  agentType,
  active = false,
  status,
  className = '',
}) => {
  const theme = getMindflowV2AgentTheme(agentType);
  const statusLabelText = formatThinkingStatus(status ?? (active ? 'thinking' : 'waiting'));

  return (
    <div
      className={cn('routing-pill', active ? 'routing-pill--accent' : undefined, className)}
      style={{
        borderColor: active ? theme.accent : undefined,
        background: active ? theme.soft : undefined,
        color: 'var(--text-secondary)',
      }}
    >
      <span className="routing-pill-dot" style={{ background: theme.accent, animationPlayState: active ? 'running' : 'paused' }} />
      <span>{theme.shortLabel}</span>
      <span className="routing-pill-sep">/</span>
      <span>{statusLabelText}</span>
    </div>
  );
};

export const ThinkingNotifierRow: React.FC<ThinkingNotifierRowProps> = ({
  activeAgents,
  statuses,
  className = '',
}) => {
  const ordered = useMemo(
    () => [
      'orchestrator',
      'analyst',
      'coder',
      'researcher',
    ] as MindflowV2AgentType[],
    [],
  );

  return (
    <div className={cn('flex flex-wrap gap-2', className)}>
      {ordered.map((agentType) => (
        <ThinkingNotifier
          key={agentType}
          agentType={agentType}
          active={activeAgents.includes(agentType)}
          status={statuses?.[agentType] ?? (activeAgents.includes(agentType) ? 'thinking' : 'waiting')}
        />
      ))}
    </div>
  );
};

export const ThoughtBlock: React.FC<ThoughtBlockProps> = ({
  agentType,
  title,
  status,
  content,
  summary,
  defaultExpanded = false,
  className = '',
}) => {
  const [expanded, setExpanded] = useState(defaultExpanded);
  const theme = getMindflowV2AgentTheme(agentType);
  const hasContent = normalizeText(content).length > 0;
  const headerStatus = formatThinkingStatus(status ?? (expanded ? 'expanded' : 'collapsed'));

  return (
    <motion.section
      className={cn('thought-stack', className)}
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
      style={{ '--agent-accent': theme.accent } as React.CSSProperties}
    >
      <button
        type="button"
        className="thought-pill thought-pill-button"
        onClick={() => setExpanded((current) => !current)}
        aria-expanded={expanded}
      >
        <span className="thought-synapse" aria-hidden="true">
          <span className="thought-synapse-link thought-synapse-link-a" />
          <span className="thought-synapse-link thought-synapse-link-b" />
          <span className="thought-synapse-node thought-synapse-node-a" />
          <span className="thought-synapse-node thought-synapse-node-b" />
          <span className="thought-synapse-node thought-synapse-node-c" style={{ borderColor: theme.accent, background: theme.soft }} />
        </span>

        <div className="min-w-0">
          <div className="flex min-w-0 items-center gap-2">
            <span className="thought-name">{title ?? theme.label}</span>
            <span className="thought-sep">/</span>
            <span className="thought-status">{headerStatus}</span>
          </div>
          {summary && <div className="thought-status mt-1">{summary}</div>}
        </div>

        {expanded ? <ChevronUp className="thought-chevron" size={14} /> : <ChevronDown className="thought-chevron" size={14} />}
      </button>

      {!expanded && hasContent && (
        <div style={{ padding: '0 12px 10px', display: 'flex', flexDirection: 'column', gap: 6 }}>
          <ReasoningDepthBar content={content} accent={theme.accent} />
          <span style={{ fontFamily: 'var(--font-mono, monospace)', fontSize: 11, color: 'var(--text-meta, #999)', lineHeight: 1.4 }}>
            {content.slice(0, 60).trimEnd()}{content.length > 60 ? '…' : ''}
          </span>
        </div>
      )}

      {expanded && hasContent && (
        <motion.div
          className="thought-body thought-body-expanded"
          initial={{ opacity: 0, y: -4 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.18 }}
        >
          <RichText content={content} className="thought-note" />
        </motion.div>
      )}
    </motion.section>
  );
};

export const DelegationCard: React.FC<DelegationCardProps> = ({
  title = 'Delegation / orchestration',
  subtitle,
  status = 'ativo',
  pipeline,
  summary,
  agents,
  variant = 'rich',
  accent = '#0D6E6E',
  onOpenJourney,
  className = '',
}) => {
  if (variant === 'simple') {
    const firstAgent = agents[0];

    return (
      <motion.section
        className={cn('simple-delegation-card', className)}
        initial={{ opacity: 0, y: 8 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.18 }}
        style={{ '--delegation-accent': accent } as React.CSSProperties}
      >
        <div className="simple-delegation-header">
          <div className="simple-delegation-route">
            <div className="simple-delegation-route-core">
              <span className="simple-delegation-dot" />
              <span className="simple-delegation-origin">{firstAgent?.role ?? 'Orchestrator'}</span>
              <ArrowRight size={14} className="simple-delegation-arrow" />
              <span className="simple-delegation-name">{firstAgent?.name ?? 'Delegated Agent'}</span>
            </div>
          </div>
          <span className="simple-delegation-badge">{status}</span>
        </div>

        <p className="simple-delegation-task">{summary ?? subtitle ?? 'Delegação em andamento.'}</p>
      </motion.section>
    );
  }

  return (
    <motion.section
      className={cn('delegation-card', className)}
      initial={{ opacity: 0, y: 10 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.2 }}
      style={{ '--delegation-accent': accent } as React.CSSProperties}
    >
      <div className="delegation-card-header">
        <div className="delegation-card-copy">
          <div className="delegation-card-title">{title}</div>
          <p className="delegation-card-subtitle">{subtitle ?? 'Delegação de trabalho para agentes especializados.'}</p>
        </div>

        <div className="flex flex-col items-end gap-2">
          <span className="delegation-card-pipeline">{pipeline ?? 'ativo'}</span>
          <span className="delegation-card-footer-tag">{status}</span>
          {onOpenJourney && (
            <button
              type="button"
              onClick={onOpenJourney}
              style={{
                display: 'flex',
                alignItems: 'center',
                gap: 4,
                padding: '3px 8px',
                borderRadius: 8,
                border: '1px solid var(--line-primary, #E5E5E5)',
                background: 'transparent',
                cursor: 'pointer',
                fontFamily: 'var(--font-mono, monospace)',
                fontSize: 10,
                fontWeight: 600,
                color: accent,
                letterSpacing: '0.05em',
              }}
            >
              percurso ↗
            </button>
          )}
        </div>
      </div>

      <div className="delegation-card-body">
        {agents.map((agent) => (
          <div
            key={`${agent.role}-${agent.name}`}
            className="delegation-agent-row"
            style={{
              '--delegation-row-accent': agent.accent ?? accent,
            } as React.CSSProperties}
          >
            <div className="delegation-agent-line">
              <span className="simple-delegation-dot" />
              <div className="min-w-0">
                <div className="delegation-agent-name">{agent.name}</div>
                <div className="delegation-agent-role">{agent.role}</div>
              </div>
            </div>

            <div className="delegation-agent-meta">
              <span className="delegation-agent-status">{agent.status}</span>
            </div>
          </div>
        ))}
      </div>

      {(summary || subtitle) && <div className="delegation-card-divider" />}

      <div className="delegation-card-footer">
        <div className="delegation-card-footer-copy">{summary ?? subtitle ?? '—'}</div>
        <div className="delegation-card-footer-copy">{agents.length} agentes</div>
      </div>
    </motion.section>
  );
};

export const ToolEventCard: React.FC<ToolEventCardProps> = ({
  toolName,
  status,
  args,
  result,
  error,
  elapsed,
  agentName,
  className = '',
}) => {
  const [expanded, setExpanded] = useState(status !== 'collapsed');
  const icon =
    status === 'completed' ? <CheckCircle2 size={14} /> :
    status === 'error' ? <AlertCircle size={14} /> :
    status === 'running' ? <Loader2 size={14} className="animate-spin" /> :
    <TerminalSquare size={14} />;

  const argsText = summarizeMindflowV2Value(args);
  const resultText = summarizeMindflowV2Value(result);
  const errorText = normalizeText(error);

  return (
    <motion.section
      className={cn('tool-event-card', toolToneClass(status), className)}
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
      onClick={() => setExpanded((current) => !current)}
      role="button"
      tabIndex={0}
      onKeyDown={(event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setExpanded((current) => !current);
        }
      }}
    >
      <div className="tool-event-card-header">
        <div className="tool-event-topline">
          <span className="tool-event-lead" />
          <div className="tool-event-topline-copy">
            <div className="tool-event-title">{toolName}</div>
            <span className="stream-notifier-sep">/</span>
            <span className="stream-notifier-status">{status}</span>
          </div>

          <span className="tool-event-badges">
            {elapsed && <span className="delegation-card-footer-tag">{elapsed}</span>}
            {agentName && <span className="delegation-card-footer-tag">{agentName}</span>}
          </span>
        </div>

        <div className="tool-event-meta">
          <div className="tool-event-name-row">
            {icon}
            <span className="tool-event-name">PARAMETERS</span>
          </div>
          {expanded && (
            <pre className="thought-note thought-note-pre">{argsText}</pre>
          )}
        </div>
      </div>

      {expanded && status === 'completed' && resultText && (
        <div className="tool-event-meta">
          <div className="tool-event-name-row">
            <Workflow size={14} />
            <span className="tool-event-name">RESULT</span>
          </div>
          <pre className="thought-note thought-note-pre">{resultText}</pre>
        </div>
      )}

      {expanded && status === 'error' && errorText && (
        <div className="tool-event-meta">
          <div className="tool-event-name-row">
            <AlertCircle size={14} />
            <span className="tool-event-name">ERROR</span>
          </div>
          <pre className="thought-note thought-note-pre">{errorText}</pre>
        </div>
      )}

        <div className="tool-event-summary">
        {expanded ? 'Toque para recolher esta chamada.' : 'Toque para inspecionar os dados.'}
      </div>
    </motion.section>
  );
};

export const StreamNotifier: React.FC<StreamNotifierProps> = ({
  title,
  status,
  message,
  detail,
  tone = 'neutral',
  className = '',
}) => {
  const toneClass = statusToneClass(tone);

  return (
    <motion.section
      className={cn('stream-notifier', toneClass, className)}
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
    >
      <div className="stream-notifier-header">
        <span className="stream-notifier-lead" />
        <div className="stream-notifier-copy">
          <span className="stream-notifier-title">{title}</span>
          <span className="stream-notifier-sep">/</span>
          <span className="stream-notifier-status">{status}</span>
        </div>
        <span className="stream-notifier-pulse" />
      </div>

      {(message || detail) && (
        <div className="stream-notifier-detail">
          <p className="stream-notifier-detail-copy">{message ?? detail}</p>
          {message && detail && <p className="stream-notifier-detail-copy mt-2">{detail}</p>}
        </div>
      )}
    </motion.section>
  );
};

export const MemoryRecallCard: React.FC<MemoryRecallCardProps> = ({
  source,
  status,
  label,
  count,
  detail,
  agentName,
  done = false,
  className = '',
}) => {
  const Icon = source === 'database' ? Database : Search;
  const title = label ?? formatSourceLabel(source);
  const countLabel = typeof count === 'number' ? `${count} ${source === 'database' ? 'registros' : 'fragmentos'}` : null;

  return (
    <motion.section
      className={cn('memory-event', memoryToneClass(source), className)}
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
    >
      <div className="memory-event-header">
        <Icon size={14} className="memory-event-icon" />
        <span className="memory-event-title">{title}</span>
        <span className="memory-event-sep">/</span>
        <span className="memory-event-status">{status}</span>
        {countLabel && <span className="memory-event-key">{countLabel}</span>}
        {done && <span className="memory-event-agent">concluído</span>}
        {agentName && <span className="memory-event-agent">{agentName}</span>}
      </div>

      {(detail || countLabel) && (
        <div className="memory-event-preview">
          <pre>{detail ?? countLabel ?? '—'}</pre>
        </div>
      )}
    </motion.section>
  );
};

interface AgentTodoListProps {
  delegations: DelegationCardProps[];
  className?: string;
}

export interface ChatDiagnosticProps {
  variant: 'scope-escape' | 'slow-run';
  elapsed?: string;
  className?: string;
}

export interface DiagnosticNotifierProps {
  message: string;
  code?: string;
  recoverable?: boolean;
  className?: string;
}

export const AgentTodoList: React.FC<AgentTodoListProps> = ({ delegations, className = '' }) => {
  if (delegations.length === 0) return null;
  return (
    <motion.section
      className={cn(className)}
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.2 }}
      style={{
        borderRadius: 18,
        background: '#FEFDFF',
        border: '1px solid #DDD6E8',
        padding: 18,
        display: 'flex',
        flexDirection: 'column',
        gap: 12,
      }}
    >
      <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 10, fontWeight: 500, color: '#8D84A0', letterSpacing: 1 }}>
        TODO-LIST DOS AGENTES
      </span>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <span style={{ fontFamily: 'Cormorant Garamond, serif', fontSize: 26, fontWeight: 500, color: '#251D2E' }}>
          Todo-list dos agentes
        </span>
        <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 10, fontWeight: 500, color: '#4A4156', background: '#F7F3FB', border: '1px solid #DDD6E8', borderRadius: 12, padding: '4px 9px' }}>
          {delegations.length} agent{delegations.length !== 1 ? 's' : ''} · live
        </span>
      </div>
      <span style={{ fontFamily: 'Familjen Grotesk, sans-serif', fontSize: 13, color: '#6E6480', lineHeight: 1.5 }}>
        As próximas tarefas permanecem visíveis acima do input.
      </span>
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 12 }}>
        {delegations.map((d) => (
          <div key={d.title} style={{ flex: '1 1 200px', minWidth: 0 }}>
            <DelegationCard {...d} variant="simple" />
          </div>
        ))}
      </div>
    </motion.section>
  );
};

interface AgentJourneyPanelProps {
  delegation: DelegationCardProps;
  steps: JourneyStep[];
  isStreaming?: boolean;
  onClose: () => void;
}

export const AgentJourneyPanel: React.FC<AgentJourneyPanelProps> = ({
  delegation,
  steps,
  isStreaming = false,
  onClose,
}) => {
  const accent = delegation.accent ?? '#0D6E6E';
  return (
    <>
      {/* Backdrop */}
      <div
        onClick={onClose}
        style={{ position: 'fixed', inset: 0, zIndex: 40 }}
      />
      {/* Panel — design CVR87/1HXuO */}
      <motion.aside
        initial={{ x: 380, opacity: 0 }}
        animate={{ x: 0, opacity: 1 }}
        exit={{ x: 380, opacity: 0 }}
        transition={{ duration: 0.22, ease: 'easeOut' }}
        style={{
          position: 'fixed',
          top: 0,
          right: 0,
          bottom: 0,
          width: 380,
          background: 'var(--surface, #FFFFFF)',
          borderLeft: '1px solid var(--line-primary, #E5E5E5)',
          zIndex: 50,
          display: 'flex',
          flexDirection: 'column',
          gap: 12,
          padding: 16,
          overflowY: 'auto',
        }}
      >
        {/* Header */}
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 4 }}>
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 12, fontWeight: 600, color: 'var(--text-meta, #666)' }}>
              Percurso dos Agentes
            </span>
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, fontWeight: 500, color: 'var(--text-meta, #999)' }}>
              Visualização lateral de execução e eventos em tempo real
            </span>
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, fontWeight: 600, color: '#0D6E6E' }}>
              MindFlow v2 · Agent Journey
            </span>
          </div>
          <button
            type="button"
            onClick={onClose}
            style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--text-meta, #999)', fontSize: 16, lineHeight: 1, padding: 4 }}
            aria-label="Fechar painel"
          >
            ✕
          </button>
        </div>

        {/* Delegation summary */}
        <div style={{ borderRadius: 12, background: 'var(--surface-elevated, #FAFAFA)', border: '1px solid var(--line-primary, #E5E5E5)', padding: 16, display: 'flex', flexDirection: 'column', gap: 12 }}>
          <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 11, fontWeight: 600, color: accent, letterSpacing: 2, textTransform: 'uppercase' }}>
            {delegation.agents[0] ? `Delegated to ${delegation.agents[0].name}` : delegation.title}
          </span>
          {delegation.summary && (
            <span style={{ fontFamily: 'Inter, sans-serif', fontSize: 13, color: 'var(--text-secondary, #666)', lineHeight: 1.4 }}>
              {delegation.summary}
            </span>
          )}
          <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
            <span style={{ width: 8, height: 8, borderRadius: '50%', background: accent, flexShrink: 0 }} />
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, fontWeight: 500, color: 'var(--text-meta, #666)' }}>
              {delegation.status}
            </span>
          </div>
        </div>

        {/* Tracker pill */}
        {isStreaming && (
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, borderRadius: 20, background: 'var(--surface, #FFF)', border: '1px solid var(--line-primary, #E5E5E5)', padding: '6px 12px' }}>
            <span style={{ width: 8, height: 8, borderRadius: '50%', background: '#0D6E6E', flexShrink: 0 }} />
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, fontWeight: 500, color: 'var(--text-meta, #666)' }}>
              ... rastreando progresso do agente
            </span>
          </div>
        )}

        {/* Events list */}
        <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, fontWeight: 600, color: 'var(--text-meta, #999)', letterSpacing: 1.5, textTransform: 'uppercase' }}>
          Eventos no Chat
        </span>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 8, flex: 1 }}>
          {steps.length === 0 ? (
            <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 11, color: 'var(--text-meta, #999)' }}>
              Nenhum evento registrado para este agente.
            </span>
          ) : (
            steps.map((step) => {
              const theme = getMindflowV2AgentTheme(step.agentType ?? 'orchestrator');
              return (
                <div
                  key={step.id}
                  style={{
                    display: 'flex',
                    alignItems: 'center',
                    gap: 8,
                    borderRadius: 20,
                    background: 'var(--surface, #FFF)',
                    border: '1px solid var(--line-primary, #E5E5E5)',
                    padding: '6px 14px',
                  }}
                >
                  <span style={{ width: 7, height: 7, borderRadius: '50%', background: step.status === 'done' ? theme.accent : step.status === 'error' ? '#E11D48' : theme.accent, opacity: step.status === 'done' ? 1 : 0.5, flexShrink: 0 }} />
                  <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 11, fontWeight: 500, color: 'var(--text-primary, #1A1A1A)', flex: 1, minWidth: 0, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                    {step.title}
                  </span>
                  <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 10, color: 'var(--text-meta, #999)', flexShrink: 0 }}>
                    {step.status === 'done' ? '✓' : step.status === 'error' ? '✕' : '…'}
                  </span>
                </div>
              );
            })
          )}
        </div>
      </motion.aside>
    </>
  );
};

// DiagnosticNotifier - Critical error display component
export const DiagnosticNotifier: React.FC<DiagnosticNotifierProps> = ({
  message,
  code,
  recoverable = false,
  className = '',
}) => {
  return (
    <motion.div
      className={cn(className)}
      initial={{ opacity: 0, y: 6 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
      style={{
        padding: '12px',
        borderRadius: '8px',
        border: '1px solid #FCA5A5',
        background: '#FEF2F2',
        fontFamily: 'var(--font-mono, monospace)',
        fontSize: '0.875rem',
        color: 'var(--state-error, #E11D48)',
      }}
    >
      <div style={{ fontWeight: 600, marginBottom: '4px' }}>
        {code ? `[${code}] ` : ''}Error
      </div>
      <div>{message}</div>
      {!recoverable && (
        <div style={{ marginTop: '8px', fontSize: '0.75rem', opacity: 0.75 }}>
          Este erro não é recuperável.
        </div>
      )}
    </motion.div>
  );
};

// Matches scopeEscapeNotifier / slowRunNotifier design from Pencil
export const ChatDiagnostic: React.FC<ChatDiagnosticProps> = ({ variant, elapsed, className = '' }) => {
  const isScopeEscape = variant === 'scope-escape';
  return (
    <motion.div
      className={cn(className)}
      initial={{ opacity: 0, y: 6 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.18 }}
      style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 14px', borderRadius: 14, background: '#FDFBFF', border: '1px solid #DED6E8' }}
    >
      <span style={{ width: 10, height: 10, borderRadius: '50%', background: '#FFFFFF', border: '1px solid #F7C873', flexShrink: 0 }} />
      <span style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
        <span style={{ fontFamily: 'Cormorant Garamond, serif', fontSize: 18, fontWeight: 500, color: '#251D2E' }}>
          {isScopeEscape ? 'Scope' : 'Performance'}
        </span>
        <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 11, color: '#B2A8C2' }}>/</span>
        <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 11, fontWeight: 500, color: '#B45309' }}>
          {isScopeEscape ? 'fora do escopo' : `execução lenta${elapsed ? ` · ${elapsed}` : ''}`}
        </span>
      </span>
    </motion.div>
  );
};

export const JourneyTimeline: React.FC<JourneyTimelineProps> = ({
  title = 'Journey',
  subtitle = 'Jornada de trabalho dos agentes delegados.',
  steps,
  summary,
  durationLabel,
  liveLabel = 'ao vivo',
  activeStepId,
  className = '',
}) => {
  const [selectedStepId, setSelectedStepId] = useState<string | null>(null);
  const selectedId = selectedStepId ?? activeStepId ?? steps[steps.length - 1]?.id ?? steps[0]?.id ?? '';
  const activeStep = steps.find((step) => step.id === selectedId) ?? steps[steps.length - 1] ?? steps[0];
  const visibleSteps = steps.slice(0, Math.max(steps.length, 1));

  return (
    <motion.section
      className={cn('delegation-inspector-shell', className)}
      initial={{ opacity: 0, y: 10 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.2 }}
    >
      <div className="delegation-inspector-header">
        <div className="delegation-inspector-title">{title}</div>
        <div className="delegation-inspector-subtitle">{subtitle}</div>
      </div>

      <div className="delegation-inspector-body">
        <aside className="delegation-inspector-rail">
          <div className="delegation-inspector-rail-list">
            {visibleSteps.map((step) => {
              const theme = getMindflowV2AgentTheme(step.agentType ?? 'orchestrator');
              const isSelected = step.id === (activeStep?.id ?? selectedId);

              return (
                <button
                  key={step.id}
                  type="button"
                  className={cn('delegation-rail-card', isSelected && 'is-selected')}
                  onClick={() => setSelectedStepId(step.id)}
                >
                  <div className="delegation-rail-card-title">{step.title}</div>
                  <div className="delegation-rail-card-meta" style={{ color: theme.accent }}>
                    {statusLabel(step.status)}
                  </div>
                </button>
              );
            })}
          </div>
        </aside>

        <div className="delegation-inspector-stage">
          <div className="delegation-stage-backdrop delegation-stage-backdrop-1" />
          <div className="delegation-stage-backdrop delegation-stage-backdrop-2" />

          <div className="delegation-stage-front">
            <div className="delegation-stage-front-header">
              <div className="delegation-stage-front-agent">
                <span className="delegation-agent-glyph">
                  <Route size={15} />
                </span>
                <div>
                  <div className="delegation-stage-front-label">{activeStep?.title ?? 'Journey'}</div>
                  <div className="delegation-stage-front-meta">{activeStep?.meta ?? 'em andamento'}</div>
                </div>
              </div>

              <span className={cn(
                'delegation-stage-status',
                activeStep?.status === 'live' && 'delegation-stage-status--live',
                activeStep?.status === 'done' && 'delegation-stage-status--done',
                (activeStep?.status === 'queued' || activeStep?.status === 'waiting') && 'delegation-stage-status--waiting',
                activeStep?.status === 'error' && 'delegation-stage-status--error',
              )}>
                {statusLabel(activeStep?.status ?? 'waiting')}
              </span>
            </div>

            <div className="delegation-stage-steps">
              {steps.map((step, index) => {
                const isLive = step.id === activeStep?.id;
                const theme = getMindflowV2AgentTheme(step.agentType ?? 'orchestrator');

                return (
                  <div key={step.id} className="delegation-step">
                    <div className="delegation-step-rail">
                      <span
                        className={cn(
                          'delegation-step-dot',
                          isLive && 'delegation-step-dot--live',
                          step.status === 'done' && 'delegation-step-dot--done',
                          (step.status === 'queued' || step.status === 'waiting') && 'delegation-step-dot--waiting',
                          step.status === 'error' && 'delegation-step-dot--error',
                        )}
                        style={{ color: theme.accent }}
                      >
                        {index + 1}
                      </span>
                      {index < steps.length - 1 && <span className="delegation-step-line" />}
                    </div>

                    <div className="delegation-step-content">
                      <div className="delegation-step-header">
                        <div className="delegation-step-title">{step.title}</div>
                        <div className="delegation-step-meta">{statusLabel(step.status)}</div>
                      </div>
                      <div className="delegation-step-detail">{step.detail}</div>
                    </div>
                  </div>
                );
              })}
            </div>

            <div className="delegation-stage-footer">
              <span className="routing-pill routing-pill--accent">
                <span className="routing-pill-dot" />
                <span>{liveLabel}</span>
              </span>
              {durationLabel && <span className="delegation-stage-footer-copy">{durationLabel}</span>}
              {summary && <span className="delegation-stage-footer-copy">{summary}</span>}
            </div>
          </div>
        </div>
      </div>
    </motion.section>
  );
};
