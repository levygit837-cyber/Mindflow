import React, { useEffect, useMemo, useState } from 'react';
import type { StreamEvent } from '../../hooks/useOmniStream';
import type { AgentType } from '../../types/agentTypes';
import {
  buildStreamPresentation,
  getMindflowV2ElapsedLabel,
  type StreamError,
} from './streamPresentation';
import {
  AgentJourneyPanel,
  AgentTodoList,
  ChatDiagnostic,
  DelegationCard,
  JourneyTimeline,
  MemoryRecallCard,
  StreamNotifier,
  ThoughtBlock,
  ThinkingNotifierRow,
  ToolEventCard,
} from './streamComponents';
import {
  getMindflowV2AgentTheme,
  resolveMindflowV2AgentType,
  resolveMindflowV2Tone,
  type MindflowV2AgentType,
} from './mindflowV2';

interface ChatStreamFeedProps {
  events: StreamEvent[];
  isStreaming: boolean;
  streamingAgent: { type: AgentType; name: string };
  startedAt?: Date | null;
  className?: string;
}

function resolveDisplayAgentType(agentType: AgentType | string): MindflowV2AgentType {
  return resolveMindflowV2AgentType(agentType);
}

// Matches the errorNotifier design from the Pencil (cornerRadius 14, border #DED6E8)
function DiagnosticNotifier({ error }: { error: StreamError }) {
  return (
    <div
      style={{
        display: 'flex',
        alignItems: 'center',
        gap: 12,
        padding: '12px 14px',
        borderRadius: 14,
        background: '#FDFBFF',
        border: '1px solid #DED6E8',
      }}
    >
      <span
        style={{
          width: 10,
          height: 10,
          borderRadius: '50%',
          background: '#FFFFFF',
          border: '1px solid #F4A6B8',
          flexShrink: 0,
        }}
      />
      <span style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
        <span style={{ fontFamily: 'Cormorant Garamond, serif', fontSize: 18, fontWeight: 500, color: '#251D2E' }}>
          Run
        </span>
        <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 11, color: '#B2A8C2' }}>/</span>
        <span style={{ fontFamily: 'Azeret Mono, monospace', fontSize: 11, fontWeight: 500, color: '#9F1239' }}>
          {error.message}
        </span>
      </span>
    </div>
  );
}

export const ChatStreamFeed: React.FC<ChatStreamFeedProps> = ({
  events,
  isStreaming,
  streamingAgent,
  startedAt,
  className = '',
}) => {
  const [, setLiveTick] = useState(0);
  const [openDelegationId, setOpenDelegationId] = useState<string | null>(null);

  useEffect(() => {
    if (!isStreaming || !startedAt) {
      return undefined;
    }

    const timer = window.setInterval(() => {
      setLiveTick((current) => current + 1);
    }, 1000);

    return () => window.clearInterval(timer);
  }, [isStreaming, startedAt]);

  const presentation = useMemo(
    () => buildStreamPresentation(events, isStreaming),
    [events, isStreaming],
  );

  const activeAgentType = resolveDisplayAgentType(streamingAgent.type);
  const liveLabel = getMindflowV2ElapsedLabel(startedAt);
  const streamTheme = getMindflowV2AgentTheme(activeAgentType);
  const elapsedMs = startedAt ? Date.now() - startedAt.getTime() : 0;
  const isSlowRun = isStreaming && elapsedMs > 30_000;
  const thinkingStatuses = isStreaming
    ? presentation.thinkingStatuses
    : Object.fromEntries(
        presentation.activeAgents.map((agent) => [agent, 'concluído']),
      ) as Partial<Record<MindflowV2AgentType, string>>;
  const hasHistory = presentation.thoughts.length > 0
    || presentation.delegations.length > 0
    || presentation.toolEvents.length > 0
    || presentation.notifiers.length > 0
    || presentation.memoryEvents.length > 0
    || presentation.journey.steps.length > 0;

  return (
    <div className={className ? `grid gap-4 ${className}` : 'grid gap-4'}>
      {isStreaming && presentation.delegations.length > 0 && (
        <AgentTodoList delegations={presentation.delegations} />
      )}

      <ThinkingNotifierRow
        activeAgents={presentation.activeAgents.length > 0 ? presentation.activeAgents : [activeAgentType]}
        statuses={thinkingStatuses}
      />

      {isStreaming && !hasHistory && (
        <StreamNotifier
          title={streamTheme.label}
          status="processando"
          message={`Aguardando a primeira atualização de ${streamingAgent.name}.`}
          tone="accent"
        />
      )}

      {presentation.thoughts.map((thought) => (
        <ThoughtBlock
          key={thought.id}
          agentType={thought.agentType}
          title={thought.title}
          status={thought.status}
          content={thought.content}
          summary={thought.summary}
          defaultExpanded={thought.defaultExpanded}
        />
      ))}

      {presentation.delegations.map((delegation) => (
        <DelegationCard
          key={delegation.id}
          title={delegation.title}
          subtitle={delegation.subtitle}
          status={delegation.status}
          pipeline={delegation.pipeline}
          summary={delegation.summary}
          agents={delegation.agents}
          variant={delegation.variant}
          accent={delegation.accent}
          onOpenJourney={() => setOpenDelegationId(delegation.id)}
        />
      ))}

      {openDelegationId !== null && (() => {
        const delegation = presentation.delegations.find((d) => d.id === openDelegationId);
        if (!delegation) return null;
        const agentTypes = new Set(delegation.agents.map((a) => a.agentType).filter(Boolean));
        const filteredSteps = presentation.journey.steps.filter(
          (s) => !s.agentType || agentTypes.has(s.agentType),
        );
        return (
          <AgentJourneyPanel
            delegation={delegation}
            steps={filteredSteps}
            isStreaming={isStreaming}
            onClose={() => setOpenDelegationId(null)}
          />
        );
      })()}

      {presentation.toolEvents.map((toolEvent) => (
        <ToolEventCard
          key={toolEvent.id}
          toolName={toolEvent.name}
          status={!isStreaming && toolEvent.status === 'running' ? 'collapsed' : toolEvent.status}
          args={toolEvent.args}
          result={toolEvent.result}
          error={toolEvent.error}
          elapsed={toolEvent.elapsed}
          agentName={toolEvent.agentName}
        />
      ))}

      {presentation.memoryEvents.map((memoryEvent) => (
        <MemoryRecallCard
          key={memoryEvent.id}
          source={memoryEvent.source}
          status={memoryEvent.status}
          label={memoryEvent.label}
          count={memoryEvent.count}
          detail={memoryEvent.detail}
          agentName={memoryEvent.agentName}
          done={memoryEvent.done}
        />
      ))}

      {presentation.notifiers.map((notifier) => (
        <StreamNotifier
          key={notifier.id}
          title={notifier.title}
          status={notifier.status}
          message={notifier.message}
          detail={notifier.detail}
          tone={notifier.tone ?? resolveMindflowV2Tone(notifier.status)}
        />
      ))}

      {presentation.errors.map((error) => (
        <DiagnosticNotifier key={error.id} error={error} />
      ))}

      {presentation.diagnostics.scopeEscape && (
        <ChatDiagnostic variant="scope-escape" />
      )}

      {isSlowRun && (
        <ChatDiagnostic variant="slow-run" elapsed={liveLabel} />
      )}

      {presentation.journey.steps.length > 0 && (
        <JourneyTimeline
          title="Jornada"
          subtitle="Jornada de trabalho dos agentes delegados e marcos de execução."
          steps={presentation.journey.steps}
          summary={presentation.journey.summary}
          durationLabel={liveLabel}
          liveLabel={isStreaming ? 'ao vivo' : 'finalizado'}
          activeStepId={presentation.journey.activeStepId}
        />
      )}
    </div>
  );
};
