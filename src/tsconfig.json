{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2022"
        ],
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": ".",
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "components/*"
            ],
            "@services/*": [
                "services/*"
            ],
            "@state/*": [
                "state/*"
            ],
            "@hooks/*": [
                "hooks/*"
            ],
            "@summarizer/*": [
                "summarizer/*"
            ],
            "@screens/*": [
                "screens/*"
            ],
            "@ink/*": [
                "ink/*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}