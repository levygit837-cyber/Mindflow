{
  "name": "@mindflow/cli",
  "version": "0.1.0",
  "description": "MindFlow Terminal CLI with multi-agent orchestration visualization",
  "type": "module",
  "bin": {
    "mindflow-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "ink": "^5.0.1",
    "zustand": "^4.5.0",
    "chalk": "^5.3.0",
    "figures": "^6.1.0",
    "date-fns": "^3.3.1",
    "axios": "^1.6.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/node": "^20.11.19",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
