APP_NAME=OmniMind Python Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=0

POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_CONTAINER_NAME=omnimind-postgres-v1
POSTGRES_DB=omnimind_v1
POSTGRES_USER=omnimind_app
POSTGRES_PASSWORD=omnimind_dev_local_2026
POSTGRES_PORT=5433

REDIS_CONTAINER_NAME=omnimind-redis-v1
REDIS_PORT=6380

DATABASE_URL=postgresql+psycopg://omnimind_app:omnimind_dev_local_2026@127.0.0.1:5433/omnimind_v1
REDIS_URL=redis://127.0.0.1:6380/0

DEFAULT_PROVIDER=vertexai
DEFAULT_MODEL=gemini-3-flash-preview
ENABLE_DECOMPOSITION_THINKING=0

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceaccount.json
VERTEXAI_CREDENTIALS_PATH=/absolute/path/to/serviceaccount.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
OLLAMA_BASE_URL=http://localhost:11434

SEARXNG_URL=http://localhost:8080

GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Mind allowlist bootstrap (comma-separated absolute paths)
OMNIMIND_ALLOWED_PATHS=/home/levybonito/Projetos

# Desktop client defaults
OMNIMIND_API_URL=http://127.0.0.1:8000
CODEX_HOME=/home/levybonito/.codex

# Optional desktop launcher extras
OMNIMIND_START_GRPC=0
OMNIMIND_START_WORKER=0
