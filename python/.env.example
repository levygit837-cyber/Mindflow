APP_NAME=MindFlow Python Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=0

POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_CONTAINER_NAME=mindflow-postgres-v1
POSTGRES_DB=mindflow_v1
POSTGRES_USER=mindflow_app
POSTGRES_PASSWORD=mindflow_dev_local_2026
POSTGRES_PORT=5433

REDIS_CONTAINER_NAME=mindflow-redis-v1
REDIS_PORT=6380

# RabbitMQ for new worker system
RABBITMQ_CONTAINER_NAME=mindflow-rabbitmq-v1
RABBITMQ_PORT=5673
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5673/
RABBITMQ_HOST=127.0.0.1
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

DATABASE_URL=postgresql+psycopg://mindflow_app:mindflow_dev_local_2026@127.0.0.1:5433/mindflow_v1
REDIS_URL=redis://127.0.0.1:6380/0

DEFAULT_PROVIDER=vertexai
DEFAULT_MODEL=gemini-3-flash-preview
ENABLE_DECOMPOSITION_THINKING=0

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceaccount.json
VERTEXAI_CREDENTIALS_PATH=/absolute/path/to/serviceaccount.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
OLLAMA_BASE_URL=http://localhost:11434

SEARXNG_URL=http://localhost:8080

GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Mind allowlist bootstrap (comma-separated absolute paths)
MINDFLOW_ALLOWED_PATHS=/home/levybonito/Projetos

# Desktop client defaults
MINDFLOW_API_URL=http://127.0.0.1:8000
CODEX_HOME=/home/levybonito/.codex

# Optional desktop launcher extras
MINDFLOW_START_GRPC=0
MINDFLOW_START_WORKER=0
MINDFLOW_USE_NEW_WORKERS=0
