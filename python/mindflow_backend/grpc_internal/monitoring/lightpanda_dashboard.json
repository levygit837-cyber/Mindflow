{
  "dashboard": {
    "title": "LightPanda Browser Monitoring",
    "uid": "lightpanda-browser-monitoring",
    "tags": ["lightpanda", "browser", "mindflow"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Browser Instances",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "lightpanda_browser_active_instances",
            "legendFormat": "Active",
            "refId": "A"
          },
          {
            "expr": "lightpanda_browser_instances_total",
            "legendFormat": "Total",
            "refId": "B"
          }
        ]
      },
      {
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "rate(lightpanda_browser_requests_total[5m])",
            "legendFormat": "Requests/sec",
            "refId": "A"
          },
          {
            "expr": "rate(lightpanda_browser_successful_requests_total[5m])",
            "legendFormat": "Successful/sec",
            "refId": "B"
          },
          {
            "expr": "rate(lightpanda_browser_failed_requests_total[5m])",
            "legendFormat": "Failed/sec",
            "refId": "C"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "lightpanda_browser_error_rate",
            "legendFormat": "Error Rate",
            "refId": "A"
          }
        ]
      },
      {
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "lightpanda_browser_cpu_usage_percent",
            "legendFormat": "CPU %",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "lightpanda_browser_memory_usage_mb",
            "legendFormat": "Memory MB",
            "refId": "A"
          },
          {
            "expr": "lightpanda_browser_total_memory_usage_mb",
            "legendFormat": "Total Memory MB",
            "refId": "B"
          }
        ]
      },
      {
        "title": "Request Duration",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "lightpanda_browser_request_duration_seconds_p50",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "lightpanda_browser_request_duration_seconds_p95",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "lightpanda_browser_request_duration_seconds_p99",
            "legendFormat": "P99",
            "refId": "C"
          }
        ]
      },
      {
        "title": "Request Duration Histogram",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(lightpanda_browser_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(lightpanda_browser_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(lightpanda_browser_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ]
      },
      {
        "title": "Snapshot Count",
        "type": "graph",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "lightpanda_browser_snapshot_count",
            "legendFormat": "Snapshots",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Uptime",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
        "targets": [
          {
            "expr": "lightpanda_browser_uptime_seconds",
            "legendFormat": "Uptime (s)",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Request Duration Distribution",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "lightpanda_browser_request_duration_seconds_p50",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "lightpanda_browser_request_duration_seconds_p95",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "lightpanda_browser_request_duration_seconds_p99",
            "legendFormat": "P99",
            "refId": "C"
          }
        ]
      },
      {
        "title": "Resource Usage Summary",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 24},
        "targets": [
          {
            "expr": "lightpanda_browser_cpu_usage_percent",
            "legendFormat": "CPU %",
            "refId": "A"
          },
          {
            "expr": "lightpanda_browser_memory_usage_mb",
            "legendFormat": "Memory MB",
            "refId": "B"
          }
        ]
      },
      {
        "title": "Request Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "1 - lightpanda_browser_error_rate",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.9},
                {"color": "green", "value": 0.95}
              ]
            }
          }
        }
      },
      {
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
        "targets": [
          {
            "expr": "lightpanda_browser_requests_total",
            "legendFormat": "Total Requests",
            "refId": "A"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
